# Environment Variables
# Copy this file to .env or .env.local and fill in your values.
# Never commit real credentials.

# Database (MySQL 8.4 / InnoDB)
# Use utf8mb4 on the database. Add DATABASE_SSL=true if your provider requires TLS.
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME"
DATABASE_MIGRATION_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME"
DATABASE_POOL_LIMIT="10"
DATABASE_SSL="false"
DATABASE_SSL_REJECT_UNAUTHORIZED="true"

# One-time PostgreSQL to MySQL data migration only.
# Keep Neon available until MySQL is fully verified.
POSTGRES_SOURCE_URL="postgresql://USER:PASSWORD@HOST/DATABASE_NAME?sslmode=require"

# Authentication
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# Admin Credentials
ADMIN_EMAIL="admin@headhunters.com.au"
ADMIN_PASSWORD="change-me"

# Email (Resend)
RESEND_API_KEY="re_your_key_here"
EMAIL_FROM="Head Hunters <noreply@headhunters.com.au>"
EMAIL_TO="hello@headhunters.com.au"

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
